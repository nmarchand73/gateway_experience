---
import LanguageSwitch from '../components/LanguageSwitch.astro';
import { t, localePrefix } from '../i18n';
import type { Locale } from '../i18n';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, description = t('fr', 'site.tagline'), locale = 'fr' } = Astro.props;
const p = localePrefix(locale);

const navLinks = [
  { href: `${p}/`, labelKey: 'nav.home' },
  { href: `${p}/start/`, labelKey: 'nav.start' },
  { href: `${p}/waves/`, labelKey: 'nav.waves' },
  { href: `${p}/supplements/`, labelKey: 'nav.supplements' },
  { href: `${p}/glossary/`, labelKey: 'nav.glossary' },
  { href: `${p}/progress/`, labelKey: 'nav.progress' },
];
---

<!doctype html>
<html lang={locale} data-base={import.meta.env.BASE_URL || '/'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | Gateway Experience</title>
    <script is:inline>
      (function(){
        var p=location.pathname;
        var base=(document.documentElement.getAttribute('data-base')||'/').replace(/\/$/,'')||'';
        if(base&&p.startsWith('/en'+base)){location.replace(base+'/en'+(p.slice(('/en'+base).length)||'/'));return;}
        try{
          if(localStorage.getItem('gateway-lang')==='en'){
            var isFr=p===base||p===base+'/'||(p.startsWith(base+'/')&&!p.startsWith(base+'/en'));
            if(isFr){var after=p.slice(base.length).replace(/^\/?/,'')||'';location.replace(base+'/en/'+after);}
          }
        }catch(_){}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">{t(locale, 'nav.skipLink')}</a>
    <header class="site-header">
      <nav class="nav" aria-label={t(locale, 'nav.navLabel')}>
        <a href={`${p}/`} class="logo">Gateway</a>
        <ul class="nav-menu" id="nav-menu">
          {navLinks.map((link) => (
            <li><a href={link.href}>{t(locale, link.labelKey)}</a></li>
          ))}
        </ul>
        <div class="nav-actions">
          <LanguageSwitch locale={locale} currentPath={Astro.url.pathname} />
          <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label={t(locale, 'nav.menuOpen')}>
            <span class="hamburger"></span>
          </button>
        </div>
      </nav>
    </header>
    <main class="main" id="main">
      <div class="main-inner">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <p>{t(locale, 'footer.tagline')}</p>
    </footer>
    <script>
      (function() {
        const btn = document.querySelector('.nav-toggle');
        const menu = document.getElementById('nav-menu');
        if (!btn || !menu) return;
        btn.addEventListener('click', () => {
          const open = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!open));
          menu.classList.toggle('is-open', !open);
        });
        menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
          btn.setAttribute('aria-expanded', 'false');
          menu.classList.remove('is-open');
        }));
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #050510;
    --text: #e8f4f2;
    --text-muted: rgba(0, 230, 200, 0.75);
    --border: rgba(0, 255, 220, 0.25);
    --accent: #00e5c0;
    --accent-dim: #00b894;
    --accent2: #7c3aed;
    --nav-height: 3.5rem;
    --content-max: 960px;
    --radius: 8px;
    color-scheme: dark;
  }

  * { box-sizing: border-box; }

  html {
    font-family: 'DM Sans', system-ui, sans-serif;
    color: var(--text);
    line-height: 1.6;
    scroll-padding-top: var(--nav-height);
    background: var(--bg);
  }

  body {
    min-height: 100vh;
    background: linear-gradient(165deg, #1e1b4b 0%, #0c0c1a 40%, #0a1628 100%);
    margin: 0;
  }

  a { color: var(--accent); }
  a:hover { color: #7fffe8; }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 999;
    padding: 0.5rem 1rem;
    background: var(--accent);
    color: #000;
  }
  .skip-link:focus { left: 0; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(5, 5, 16, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 1rem;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .logo {
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .nav-menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.25rem 1rem;
    flex: 1;
    flex-wrap: wrap;
  }

  .nav-menu a {
    text-decoration: none;
    color: rgba(255,255,255,0.75);
    font-size: 0.9rem;
  }
  .nav-menu a:hover { color: var(--accent); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .nav-toggle {
    display: none;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    width: 40px;
    height: 40px;
    cursor: pointer;
  }

  .hamburger {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text);
    margin: 0 auto;
    box-shadow: 0 -6px 0 var(--text), 0 6px 0 var(--text);
  }

  @media (max-width: 720px) {
    .nav-toggle { display: block; }
    .nav-menu {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(5,5,16,0.98);
      padding: 1rem;
      border-bottom: 1px solid var(--border);
    }
    .nav-menu.is-open { display: flex; }
  }

  .main-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 1rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .card {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .hero { margin-bottom: 2rem; }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0.25rem 0 0.75rem;
    line-height: 1.15;
  }
  .lede { color: rgba(255,255,255,0.8); max-width: 60ch; }

  .crumbs { margin-bottom: 1rem; font-size: 0.9rem; }
  .crumbs a { text-decoration: none; }

  .grid-waves {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .wave-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }
  .wave-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .wave-card h2 { margin: 0 0 0.5rem; font-size: 1.15rem; }
  .wave-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .session-list { list-style: none; padding: 0; margin: 0; }
  .session-list li { border-bottom: 1px solid rgba(255,255,255,0.08); }
  .session-list a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: var(--text);
  }
  .session-list a:hover { color: var(--accent); }
  .session-idx {
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-muted);
    min-width: 2rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--text);
  }
  .chip:hover { border-color: var(--accent); }

  .btn-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
  .btn-primary {
    display: inline-block;
    padding: 0.65rem 1.25rem;
    background: var(--accent);
    color: #041210;
    font-weight: 600;
    border-radius: var(--radius);
    text-decoration: none;
  }
  .btn-secondary {
    display: inline-block;
    padding: 0.65rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
  }

  .mono { font-family: 'JetBrains Mono', monospace; }
  .muted { color: rgba(255,255,255,0.65); font-size: 0.95rem; }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }
</style>
