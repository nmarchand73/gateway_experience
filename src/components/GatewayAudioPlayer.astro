---
import { t } from '../i18n';
import type { Locale } from '../i18n';
import { resolvePdfUrl, CIA_GATEWAY_REPORT_PATH } from '../lib/media';

interface Props {
  src: string;
  downloadHref: string;
  locale: Locale;
  /** Puts playback controls first; hides spectrum/CIA behind a collapsed panel. */
  listenerMode?: boolean;
  leftHz?: number | null;
  rightHz?: number | null;
  beatHz?: number;
  focusLevel?: number;
  bandLabel?: string;
  reviewed?: boolean;
}

const {
  src,
  downloadHref,
  locale,
  listenerMode = false,
  leftHz = null,
  rightHz = null,
  beatHz,
  focusLevel,
  bandLabel = '',
  reviewed = false,
} = Astro.props;

const fmtHz = (v: number | null | undefined) =>
  v == null ? '—' : `${v.toFixed(v % 1 ? 1 : 0)} Hz`;

const ciaReportUrl = resolvePdfUrl(CIA_GATEWAY_REPORT_PATH);
---

<section class:list={['player-wrap', 'card', listenerMode && 'player-listener']} data-gateway-player>
  {listenerMode ? (
    <>
      <div class="controls controls-primary">
        <button type="button" class="btn-play btn-play-lg" data-play aria-label={t(locale, 'player.play')}>
          <span data-play-icon>▶</span>
        </button>
        <div class="timeline">
          <input type="range" min="0" max="1000" value="0" step="1" class="scrub" data-scrub aria-label={t(locale, 'player.seek')} />
          <div class="time">
            <span class="mono" data-current>0:00</span>
            <span>·</span>
            <span class="mono" data-duration>—:—</span>
          </div>
        </div>
        <div class="right">
          <button type="button" class="btn-skip" data-skip="-10">−10s</button>
          <button type="button" class="btn-skip" data-skip="10">+10s</button>
          <label class="speed">
            <span class="sr-only">{t(locale, 'player.speed')}</span>
            <select data-speed>
              <option value="0.8">0.8×</option>
              <option value="1" selected>1×</option>
              <option value="1.25">1.25×</option>
              <option value="1.5">1.5×</option>
            </select>
          </label>
          <a class="chip" href={downloadHref} download>{t(locale, 'session.download')}</a>
        </div>
      </div>

      <audio preload="metadata" src={src} data-audio crossorigin="anonymous">
        <p class="muted">{t(locale, 'player.noFlac')} <a href={downloadHref}>{t(locale, 'session.download')}</a></p>
      </audio>

      <details class="tech-panel">
        <summary>{t(locale, 'session.technicalDetails')}</summary>
        <div class="freq-strip" aria-label={t(locale, 'session.frequencies')}>
          <div class="freq-cell">
            <span class="freq-k">{t(locale, 'session.left')}</span>
            <span class="freq-v mono" data-freq-l>{fmtHz(leftHz)}</span>
          </div>
          <div class="freq-cell">
            <span class="freq-k">{t(locale, 'session.right')}</span>
            <span class="freq-v mono" data-freq-r>{fmtHz(rightHz)}</span>
          </div>
          <div class="freq-cell accent">
            <span class="freq-k">{t(locale, 'session.beat')}</span>
            <span class="freq-v mono">{beatHz != null ? `${beatHz} Hz` : '—'}</span>
          </div>
          <div class="freq-cell">
            <span class="freq-k">{t(locale, 'session.focus')}</span>
            <span class="freq-v mono">{focusLevel ?? '—'}</span>
          </div>
          {bandLabel && (
            <div class="freq-cell wide">
              <span class="freq-k">{t(locale, 'session.band')}</span>
              <span class="freq-v">{bandLabel}</span>
            </div>
          )}
        </div>
        {!reviewed && <p class="freq-note muted">{t(locale, 'session.unreviewed')}</p>}
        {ciaReportUrl && (
          <details class="cia-report card-inset">
            <summary>{t(locale, 'player.ciaReportTitle')}</summary>
            <p class="cia-body">{t(locale, 'player.ciaReportBody')}</p>
            <p class="cia-body muted">{t(locale, 'player.ciaReportSpectrum')}</p>
            <p>
              <a class="chip" href={ciaReportUrl} target="_blank" rel="noopener">
                {t(locale, 'player.ciaReportLink')}
              </a>
            </p>
          </details>
        )}
        <p class="muted player-hint">{t(locale, 'session.playerHint')}</p>
        <div class="spectrum-row">
          <div class="viz-block">
            <div class="viz-head">
              <span class="viz-label">{t(locale, 'player.spectrumL')}</span>
              <span class="viz-range mono">{t(locale, 'player.spectrumRange')}</span>
            </div>
            <canvas class="viz-canvas" data-viz-l width="640" height="180" role="img" aria-label={t(locale, 'player.spectrumL')}></canvas>
          </div>
          <div class="viz-block">
            <div class="viz-head">
              <span class="viz-label">{t(locale, 'player.spectrumR')}</span>
              <span class="viz-range mono">{t(locale, 'player.spectrumRange')}</span>
            </div>
            <canvas class="viz-canvas" data-viz-r width="640" height="180" role="img" aria-label={t(locale, 'player.spectrumR')}></canvas>
          </div>
        </div>
      </details>
    </>
  ) : (
    <>
      <div class="freq-strip" aria-label={t(locale, 'session.frequencies')}>
        <div class="freq-cell">
          <span class="freq-k">{t(locale, 'session.left')}</span>
          <span class="freq-v mono" data-freq-l>{fmtHz(leftHz)}</span>
        </div>
        <div class="freq-cell">
          <span class="freq-k">{t(locale, 'session.right')}</span>
          <span class="freq-v mono" data-freq-r>{fmtHz(rightHz)}</span>
        </div>
        <div class="freq-cell accent">
          <span class="freq-k">{t(locale, 'session.beat')}</span>
          <span class="freq-v mono">{beatHz != null ? `${beatHz} Hz` : '—'}</span>
        </div>
        <div class="freq-cell">
          <span class="freq-k">{t(locale, 'session.focus')}</span>
          <span class="freq-v mono">{focusLevel ?? '—'}</span>
        </div>
        {bandLabel && (
          <div class="freq-cell wide">
            <span class="freq-k">{t(locale, 'session.band')}</span>
            <span class="freq-v">{bandLabel}</span>
          </div>
        )}
      </div>
      {!reviewed && <p class="freq-note muted">{t(locale, 'session.unreviewed')}</p>}

      {ciaReportUrl && (
        <details class="cia-report card-inset" open>
          <summary>{t(locale, 'player.ciaReportTitle')}</summary>
          <p class="cia-body">{t(locale, 'player.ciaReportBody')}</p>
          <p class="cia-body muted">{t(locale, 'player.ciaReportSpectrum')}</p>
          <p>
            <a class="chip" href={ciaReportUrl} target="_blank" rel="noopener">
              {t(locale, 'player.ciaReportLink')}
            </a>
          </p>
        </details>
      )}

      <p class="muted player-hint">{t(locale, 'session.playerHint')}</p>

      <audio preload="metadata" src={src} data-audio crossorigin="anonymous">
        <p class="muted">{t(locale, 'player.noFlac')} <a href={downloadHref}>{t(locale, 'session.download')}</a></p>
      </audio>

      <div class="spectrum-row">
        <div class="viz-block">
          <div class="viz-head">
            <span class="viz-label">{t(locale, 'player.spectrumL')}</span>
            <span class="viz-range mono">{t(locale, 'player.spectrumRange')}</span>
          </div>
          <canvas class="viz-canvas" data-viz-l width="640" height="180" role="img" aria-label={t(locale, 'player.spectrumL')}></canvas>
        </div>
        <div class="viz-block">
          <div class="viz-head">
            <span class="viz-label">{t(locale, 'player.spectrumR')}</span>
            <span class="viz-range mono">{t(locale, 'player.spectrumRange')}</span>
          </div>
          <canvas class="viz-canvas" data-viz-r width="640" height="180" role="img" aria-label={t(locale, 'player.spectrumR')}></canvas>
        </div>
      </div>

      <div class="controls">
        <button type="button" class="btn-play" data-play aria-label={t(locale, 'player.play')}>
          <span data-play-icon>▶</span>
        </button>
        <div class="timeline">
          <input type="range" min="0" max="1000" value="0" step="1" class="scrub" data-scrub aria-label={t(locale, 'player.seek')} />
          <div class="time">
            <span class="mono" data-current>0:00</span>
            <span>·</span>
            <span class="mono" data-duration>—:—</span>
          </div>
        </div>
        <div class="right">
          <button type="button" class="btn-skip" data-skip="-10">−10s</button>
          <button type="button" class="btn-skip" data-skip="10">+10s</button>
          <label class="speed">
            <span class="sr-only">{t(locale, 'player.speed')}</span>
            <select data-speed>
              <option value="0.8">0.8×</option>
              <option value="1" selected>1×</option>
              <option value="1.25">1.25×</option>
              <option value="1.5">1.5×</option>
            </select>
          </label>
          <a class="chip" href={downloadHref} download>{t(locale, 'session.download')}</a>
        </div>
      </div>
    </>
  )}
</section>

<script define:vars={{ leftHz, rightHz, beatHz }}>
  document.querySelectorAll('[data-gateway-player]').forEach((root) => {
    const audio = root.querySelector('[data-audio]');
    if (!audio) return;

    const playBtn = root.querySelector('[data-play]');
    const playIcon = root.querySelector('[data-play-icon]');
    const scrub = root.querySelector('[data-scrub]');
    const currentEl = root.querySelector('[data-current]');
    const durationEl = root.querySelector('[data-duration]');
    const speedSel = root.querySelector('[data-speed]');
    const canvasL = root.querySelector('[data-viz-l]');
    const canvasR = root.querySelector('[data-viz-r]');

    const fmt = (s) => {
      if (!isFinite(s) || s < 0) return '0:00';
      const m = Math.floor(s / 60);
      const ss = Math.floor(s % 60);
      return `${m}:${String(ss).padStart(2, '0')}`;
    };

    const setIcon = () => {
      if (playIcon) playIcon.textContent = audio.paused ? '▶' : '⏸';
    };

    let ac = null;
    let splitter = null;
    let analyserL = null;
    let analyserR = null;
    let dataL = null;
    let dataR = null;
    let startBin = 0;
    let endBin = 0;
    let raf = 0;

    const F_LOW = 20;
    const F_HIGH = 500;
    const AXIS_TICKS = [20, 100, 200, 300, 400, 500];

    const hzToX = (hz, w, pad) =>
      pad + ((hz - F_LOW) / (F_HIGH - F_LOW)) * (w - pad * 2);

    const setupGraph = async () => {
      if (ac) return;
      const AudioCtx = window.AudioContext || window.webkitAudioContext;
      if (!AudioCtx) return;
      ac = new AudioCtx();
      const source = ac.createMediaElementSource(audio);
      splitter = ac.createChannelSplitter(2);
      analyserL = ac.createAnalyser();
      analyserR = ac.createAnalyser();
      analyserL.fftSize = 2048;
      analyserR.fftSize = 2048;
      analyserL.smoothingTimeConstant = 0.85;
      analyserR.smoothingTimeConstant = 0.85;
      dataL = new Uint8Array(analyserL.frequencyBinCount);
      dataR = new Uint8Array(analyserR.frequencyBinCount);

      const nyquist = ac.sampleRate / 2;
      const binHz = nyquist / analyserL.frequencyBinCount;
      startBin = Math.max(0, Math.floor(F_LOW / binHz));
      endBin = Math.min(analyserL.frequencyBinCount, Math.ceil(F_HIGH / binHz));

      source.connect(splitter);
      splitter.connect(analyserL, 0);
      splitter.connect(analyserR, 1);
      source.connect(ac.destination);

      if (ac.state === 'suspended') await ac.resume();
      startViz();
    };

    const drawSpectrum = (canvas, data, markerHz) => {
      if (!canvas || !data) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      if (canvas.width !== Math.floor(w * dpr)) {
        canvas.width = Math.floor(w * dpr);
        canvas.height = Math.floor(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      const padX = 12;
      const top = 8;
      const axisH = 26;
      const usableH = h - top - axisH;

      ctx.fillStyle = 'rgba(5, 12, 18, 0.92)';
      ctx.fillRect(0, 0, w, h);

      ctx.strokeStyle = 'rgba(255, 255, 255, 0.08)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(padX, top + usableH);
      ctx.lineTo(w - padX, top + usableH);
      ctx.stroke();

      for (const hz of AXIS_TICKS) {
        const x = hzToX(hz, w, padX);
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
        ctx.beginPath();
        ctx.moveTo(x, top);
        ctx.lineTo(x, top + usableH);
        ctx.stroke();
      }

      const bins = endBin - startBin;
      const bars = Math.min(96, Math.max(40, Math.floor(w / 6)));
      const step = Math.max(1, Math.floor(bins / bars));
      const barW = (w - padX * 2) / bars;

      ctx.fillStyle = 'rgba(0, 229, 192, 0.88)';
      for (let i = 0; i < bars; i++) {
        let sum = 0;
        const base = startBin + i * step;
        for (let k = 0; k < step; k++) sum += data[base + k] || 0;
        const v = sum / step / 255;
        const bh = Math.max(2, v * usableH);
        ctx.fillRect(padX + i * barW, top + usableH - bh, Math.max(2, barW - 1), bh);
      }

      if (markerHz != null && markerHz >= F_LOW && markerHz <= F_HIGH) {
        const x = hzToX(markerHz, w, padX);
        ctx.strokeStyle = 'rgba(124, 58, 237, 0.95)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(x, top);
        ctx.lineTo(x, top + usableH);
        ctx.stroke();
        ctx.fillStyle = 'rgba(124, 58, 237, 0.95)';
        ctx.font = '600 11px JetBrains Mono, monospace';
        ctx.textAlign = 'center';
        ctx.fillText(`${markerHz} Hz`, x, top + 14);
      }

      ctx.fillStyle = 'rgba(255, 255, 255, 0.55)';
      ctx.font = '11px JetBrains Mono, monospace';
      ctx.textAlign = 'center';
      const labelY = top + usableH + 18;
      for (const hz of AXIS_TICKS) {
        const x = hzToX(hz, w, padX);
        ctx.fillText(String(hz), x, labelY);
      }
      ctx.textAlign = 'left';
      ctx.fillStyle = 'rgba(0, 229, 192, 0.65)';
      ctx.font = '10px JetBrains Mono, monospace';
      ctx.fillText('Hz', padX, labelY);
    };

    const render = () => {
      if (analyserL && analyserR) {
        analyserL.getByteFrequencyData(dataL);
        analyserR.getByteFrequencyData(dataR);
        drawSpectrum(canvasL, dataL, leftHz);
        drawSpectrum(canvasR, dataR, rightHz);
      }
      raf = requestAnimationFrame(render);
    };

    const startViz = () => {
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(render);
    };

    playBtn?.addEventListener('click', async () => {
      await setupGraph();
      if (audio.paused) await audio.play();
      else audio.pause();
      setIcon();
    });

    audio.addEventListener('play', setIcon);
    audio.addEventListener('pause', setIcon);

    audio.addEventListener('loadedmetadata', () => {
      if (durationEl) durationEl.textContent = fmt(audio.duration);
    });

    audio.addEventListener('timeupdate', () => {
      if (scrub && audio.duration) {
        scrub.value = String(Math.floor((audio.currentTime / audio.duration) * 1000));
      }
      if (currentEl) currentEl.textContent = fmt(audio.currentTime);
    });

    scrub?.addEventListener('input', () => {
      if (!audio.duration) return;
      audio.currentTime = (Number(scrub.value) / 1000) * audio.duration;
    });

    root.querySelectorAll('[data-skip]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const delta = Number(btn.getAttribute('data-skip'));
        audio.currentTime = Math.max(0, Math.min(audio.duration || 0, audio.currentTime + delta));
      });
    });

    speedSel?.addEventListener('change', () => {
      audio.playbackRate = Number(speedSel.value);
    });

    window.addEventListener('resize', () => {
      if (analyserL) {
        drawSpectrum(canvasL, dataL, leftHz);
        drawSpectrum(canvasR, dataR, rightHz);
      }
    });
  });
</script>

<style>
  .player-wrap { padding: 1rem 1.25rem 1.25rem; }

  .player-listener {
    padding: 1.25rem;
  }

  .player-listener audio {
    margin: 0.75rem 0 0;
  }

  .controls-primary {
    margin-bottom: 0;
  }

  .btn-play-lg {
    width: 52px;
    height: 52px;
    font-size: 1.15rem;
  }

  .tech-panel {
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .tech-panel summary {
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--text-muted);
    list-style: none;
  }

  .tech-panel summary::-webkit-details-marker { display: none; }

  .tech-panel[open] summary {
    margin-bottom: 0.75rem;
  }

  .freq-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .freq-cell {
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(0,255,220,0.15);
    border-radius: 6px;
    padding: 0.5rem 0.65rem;
  }
  .freq-cell.accent { border-color: rgba(0,229,192,0.45); }
  .freq-cell.wide { grid-column: 1 / -1; }
  .freq-k {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .freq-v { font-size: 1rem; font-weight: 600; }
  .freq-note { margin: 0 0 0.75rem; font-size: 0.8rem; }

  .player-hint { margin: 0 0 1rem; font-size: 0.85rem; }

  audio { width: 100%; margin-bottom: 0.75rem; }

  .spectrum-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    align-items: stretch;
  }

  .card-inset {
    margin-bottom: 1rem;
    padding: 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.28);
    border: 1px solid rgba(124, 58, 237, 0.35);
    border-radius: 8px;
  }

  .card-inset summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
    list-style: none;
  }

  .card-inset summary::-webkit-details-marker { display: none; }

  .cia-body {
    margin: 0.65rem 0 0.5rem;
    font-size: 0.88rem;
    line-height: 1.55;
    max-width: 72ch;
  }

  .cia-body + .cia-body { margin-top: 0.35rem; }

  .viz-block {
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(0,255,220,0.15);
    border-radius: 8px;
    padding: 0.65rem 0.75rem 0.75rem;
  }

  .viz-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 0.75rem;
    margin-bottom: 0.5rem;
  }

  .viz-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
  }

  .viz-range {
    font-size: 0.85rem;
    color: var(--accent);
  }

  .viz-canvas {
    display: block;
    width: 100%;
    height: clamp(120px, 16vw, 168px);
    min-height: 120px;
  }

  @media (max-width: 480px) {
    .spectrum-row {
      gap: 0.5rem;
    }
    .viz-block {
      padding: 0.45rem 0.5rem 0.55rem;
    }
    .viz-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.15rem;
    }
    .viz-label { font-size: 0.7rem; }
    .viz-range { font-size: 0.75rem; }
  }

  .controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .btn-play {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(0,229,192,0.15);
    color: var(--accent);
    cursor: pointer;
    font-size: 1rem;
  }

  .timeline { flex: 1; min-width: 180px; }
  .scrub { width: 100%; accent-color: var(--accent); }
  .time {
    display: flex;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .right {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-skip {
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    border-radius: 4px;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
  }

  .speed select {
    background: rgba(0,0,0,0.3);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 4px;
    padding: 0.35rem;
  }
</style>
